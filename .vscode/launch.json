{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Boda: abrir vista previa",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "env": {
        "FLASK_DEBUG": "1",
        "PORT": "5000"
      },
      "serverReadyAction": {
        "pattern": "Running on (http://[^\\s]+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}
